{
  "_comment": [
    "Copy this file to ~/.mytime-booker/config.json.",
    "The skill manages calendar.ics and projects.json automatically.",
    "This file is for optional defaults only."
  ],
  "mytime": {
    "url": "https://mytime.tietoevry.com/my_projects"
  },
  "defaults": {
    "skip_private": false,
    "range": "this-week"
  },
  "files": {
    "ics_path": "%USERPROFILE%/.mytime-booker/calendar.ics",
    "projects_path": "%USERPROFILE%/.mytime-booker/projects.json",
    "template_path": "%USERPROFILE%/.mytime-booker/timecard_template.xlsx",
    "output_path": "%USERPROFILE%/.mytime-booker/timecard_output.xlsx"
  }
}
